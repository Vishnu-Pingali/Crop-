APP_ENV=development
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_TIME_ZONE=Asia/Calcutta

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-me
# ADMIN_PASSWORD_HASH=

JWT_SECRET_KEY=replace-me
JWT_ACCESS_TTL_SECONDS=3600
JWT_ISSUER=crop-predication-chatbot
JWT_AUDIENCE=crop-predication-chatbot-api

SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

NVIDIA_API_KEY=
NVIDIA_PARAKEET_API_KEY=
NVIDIA_PARAKEET_ASR_URL=
NVIDIA_PARAKEET_FUNCTION_ID=
VOSK_MODEL_PATH=
VOSK_SAMPLE_RATE=16000
NVIDIA_MAGPIE_API_KEY=
NVIDIA_MAGPIE_TTS_URL=
NVIDIA_MAGPIE_FUNCTION_ID=
NVIDIA_MAGPIE_VOICE=Magpie-Multilingual.Female-1
CONVERSATION_AI_API_KEY=
CONVERSATION_AI_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
CONVERSATION_AI_MODEL=meta/llama-3.1-8b-instruct

VOICE_TEXT_RATE_LIMIT=30
VOICE_AUDIO_RATE_LIMIT=20
RATE_LIMIT_WINDOW_SECONDS=60
WEBSOCKET_CONNECT_RATE_LIMIT=20
MAX_PROFILE_UPLOAD_SIZE=2097152
ALLOWED_PROFILE_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif

# Future cloud secret injection bridge
SECRET_PROVIDER=env
